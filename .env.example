# Mainlayer API Key
# Get your API key at https://mainlayer.xyz/dashboard
MAINLAYER_API_KEY=ml_your_api_key_here

# Resource IDs — populated by running: npm run setup
# Each tool corresponds to a "resource" registered on Mainlayer.
# The setup script creates these and prints the IDs for you to paste here.
RESOURCE_ID_WEATHER=
RESOURCE_ID_SEARCH=
RESOURCE_ID_SUMMARY=
